// Função para alternar o status do chip
function toggleStatus(chipId) {
    const statusElement = document.getElementById(`status-${chipId}`);
    const currentStatus = statusElement.innerText;
    
    if (currentStatus === "Ativo") {
        statusElement.innerText = "Pausado";
    } else if (currentStatus === "Pausado") {
        statusElement.innerText = "Ativo";
    }
}

// Função para definir o intervalo de envio
function setInterval(chipId) {
    const interval = prompt("Digite o intervalo de envio em minutos (ex: 2-5):");
    alert(`Intervalo de envio para ${chipId} definido como: ${interval} minutos.`);
}
